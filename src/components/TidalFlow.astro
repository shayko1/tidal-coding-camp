---
// Signature hero background: code characters flowing down like a tidal current.
// Extracted from the p5 flow-field sketch, run in instance mode, brand-recoloured,
// desktop-only, and gated on visibility + prefers-reduced-motion so it never
// touches LCP/INP. p5 is dynamically imported (code-split) after the hero paints.
---
<div class="hero-fx" data-tidal-flow aria-hidden="true"></div>

<script>
  // @ts-nocheck
  const el = document.querySelector('[data-tidal-flow]');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const small = matchMedia('(max-width: 860px)').matches;
  // Progressive enhancement: skip the effect where it would cost more than it gives.
  if (el && !reduce && !small) {
    const PARAMS = {
      chars: '{} <> // 01 const let function return => ; : tide flow'.split(/\s+/),
      fontSize: 15,
      density: 170,
      flowSpeed: 1.2,
      turbulence: 2.6,
      primary: '#8FC9D4',   // sea-glass (reads on the dark teal photo)
      highlight: '#FFC857', // amber — matches the sitewide waterline
      trailOpacity: 12,
    };

    const start = async () => {
      const p5 = (await import('p5')).default;
      const scl = 40;
      const sketch = (p) => {
        let particles = [];
        let zoff = 0;
        const w = () => el.clientWidth, h = () => el.clientHeight;

        class Particle {
          constructor() { this.reset(true); }
          reset(init = false) {
            this.pos = init ? p.createVector(p.random(w()), p.random(h())) : p.createVector(p.random(w()), -30);
            this.vel = p.createVector(0, 0);
            this.acc = p.createVector(0, 0);
            this.speedMult = p.random(0.4, 1.6);
            this.sizeMult = p.random(0.5, 1.5);
            this.opacity = p.random(70, 235);
            this.isHighlight = p.random() < 0.15;
            this.char = p.random(PARAMS.chars);
          }
          update(flowField, cols, rows) {
            const x = p.floor(p.constrain(this.pos.x / scl, 0, cols - 1));
            const y = p.floor(p.constrain(this.pos.y / scl, 0, rows - 1));
            const force = flowField[x + y * cols];
            if (force) this.acc.add(force);
            this.vel.add(this.acc);
            this.vel.limit(PARAMS.flowSpeed * 4 * this.speedMult);
            this.pos.add(this.vel);
            this.acc.mult(0);
            const m = 50;
            if (this.pos.x < -m || this.pos.x > w() + m || this.pos.y < -m || this.pos.y > h() + m) this.reset();
          }
          draw() {
            p.textSize(PARAMS.fontSize * this.sizeMult);
            const c = p.color(this.isHighlight ? PARAMS.highlight : PARAMS.primary);
            c.setAlpha(this.opacity);
            p.fill(c);
            p.text(this.char, this.pos.x, this.pos.y);
          }
        }

        p.setup = () => {
          const c = p.createCanvas(w(), h());
          c.parent(el);
          p.pixelDensity(Math.min(1.5, window.devicePixelRatio || 1));
          p.textFont('monospace');
          p.textAlign(p.CENTER, p.CENTER);
          p.noStroke();
          for (let i = 0; i < PARAMS.density; i++) particles.push(new Particle());
        };

        p.draw = () => {
          p.drawingContext.globalCompositeOperation = 'destination-out';
          p.drawingContext.fillStyle = `rgba(0,0,0,${PARAMS.trailOpacity / 100})`;
          p.drawingContext.fillRect(0, 0, p.width, p.height);
          p.drawingContext.globalCompositeOperation = 'source-over';

          const cols = p.ceil(p.width / scl) + 1;
          const rows = p.ceil(p.height / scl) + 1;
          const flowField = new Array(cols * rows);
          const baseDir = p.createVector(0, 1); // Downward — the tide coming in
          for (let y = 0; y < rows; y++) {
            for (let x = 0; x < cols; x++) {
              const angle = p.noise(x * 0.1, y * 0.1, zoff) * p.TWO_PI * PARAMS.turbulence;
              const nf = p5.Vector.fromAngle(angle).mult(0.5);
              flowField[x + y * cols] = p5.Vector.add(baseDir, nf).normalize().mult(0.15);
            }
          }
          zoff += PARAMS.flowSpeed * 0.005;
          for (const pt of particles) { pt.update(flowField, cols, rows); pt.draw(); }
        };

        p.windowResized = () => p.resizeCanvas(w(), h());
      };

      const inst = new p5(sketch);
      // Pause when the hero scrolls out of view — saves cycles + battery.
      const io = new IntersectionObserver((es) => es.forEach((e) => (e.isIntersecting ? inst.loop() : inst.noLoop())));
      io.observe(el);
    };

    if ('requestIdleCallback' in window) requestIdleCallback(start, { timeout: 2000 });
    else addEventListener('load', () => setTimeout(start, 400));
  }
</script>
