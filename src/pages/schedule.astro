---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Tide Schedule — Tidal Coding Camp"
  description="The daily camp rhythm mapped to the real Brittany tide tables, plus a live tide clock and a 7-day tide almanac. Stranded hours are scheduled debugging hours."
  path="/schedule"
>
  <section class="pagehero" style="--hero-img:url(/assets/camp-lab.webp)">
    <div class="wrap">
      <p class="kicker">Tide Schedule</p>
      <h1 style="font-size:clamp(2.2rem,6vw,4.2rem)" class="wl">The water writes the timetable.</h1>
      <p class="muted" style="max-width:44ch;margin-top:1.2rem">Every camp day is mapped to the real tide tables.</p>
    </div>
  </section>
  <section class="band dark">
    <div class="wrap">
      <div class="tideboard">
        <div class="clockcard">
          <p class="kicker" style="margin-bottom:.4rem">Live tide clock · Île de tidal</p>
          <svg id="tideclock" viewBox="0 0 320 320" width="100%" style="max-width:320px;margin:auto;display:block" role="img" aria-label="Live tide clock showing the current point in the tide cycle">
            <defs><clipPath id="bowl"><circle cx="160" cy="160" r="128"/></clipPath></defs>
            <circle cx="160" cy="160" r="150" fill="none" stroke="rgba(253,246,231,.18)" stroke-width="1.5"/>
            <circle cx="160" cy="160" r="128" fill="#0E3A44" stroke="rgba(253,246,231,.25)" stroke-width="1.5"/>
            <g clip-path="url(#bowl)"><rect id="tc-water" x="20" y="160" width="280" height="280" fill="rgba(17,110,124,.9)"/><path id="tc-wave" d="" fill="none" stroke="#FFC24B" stroke-width="2.5" stroke-linecap="round"/></g>
            <g id="tc-ticks" stroke="rgba(253,246,231,.4)"></g>
            <text x="160" y="34" text-anchor="middle" fill="#FFC24B" font-size="12" font-weight="600" letter-spacing="3" font-family="Spline Sans,sans-serif">HIGH</text>
            <text x="160" y="298" text-anchor="middle" fill="#AEC8CC" font-size="12" font-weight="600" letter-spacing="3" font-family="Spline Sans,sans-serif">LOW</text>
            <g id="tc-needle" transform="rotate(0 160 160)"><line x1="160" y1="160" x2="160" y2="46" stroke="#FFC24B" stroke-width="3" stroke-linecap="round"/><circle cx="160" cy="160" r="7" fill="#FFC24B"/></g>
            <text id="tc-pct" x="160" y="200" text-anchor="middle" fill="#FDF6E7" font-size="30" font-weight="600" font-family="Fredoka,sans-serif">–%</text>
            <text x="160" y="222" text-anchor="middle" fill="#AEC8CC" font-size="10" letter-spacing="2.5" font-family="Spline Sans,sans-serif">WATER OVER CAUSEWAY</text>
          </svg>
          <div style="text-align:center;margin-top:1rem"><span class="status-pill" id="tc-status"><span class="dot"></span><span id="tc-status-text">Reading the water…</span></span></div>
          <div class="clock-readout">
            <div><b>Next turn</b><span id="tc-next">—</span></div>
            <div><b>Tide is</b><span id="tc-dir">—</span></div>
            <div><b>Cycle</b><span>12h 25m</span></div>
          </div>
          <p class="muted" style="font-size:.74rem;margin-top:1rem">A live model of the island’s tide. On camp, the mess-hall board shows the official SHOM tables.</p>
        </div>
        <div>
          <h2 class="wl" style="font-size:clamp(1.6rem,4vw,2.4rem)">A day, mapped to the water</h2>
          <ul class="rhythm">
            <li><time>07:40</time><div class="what"><b>Low-tide crossing</b><span>Supervised walk over the causeway.</span></div><span class="chip">Cross</span></li>
            <li><time>09:00</time><div class="what"><b>Dataset lab</b><span>Python and pandas — water still falling.</span></div><span class="chip">Build</span></li>
            <li class="stranded"><time>12:20</time><div class="what"><b>Causeway closes</b><span>Stranded hours begin. Leaving doesn’t.</span></div><span class="chip">Stranded</span></li>
            <li class="stranded"><time>14:00</time><div class="what"><b>Deep work</b><span>Build, instructor at the next desk.</span></div><span class="chip">Stranded</span></li>
            <li><time>16:50</time><div class="what"><b>Water drops</b><span>Demos and code review.</span></div><span class="chip">Review</span></li>
            <li><time>17:40</time><div class="what"><b>Return crossing</b><span>Back to the mainland.</span></div><span class="chip">Cross</span></li>
          </ul>
          <p class="muted" style="font-size:.85rem;margin-top:1rem">Times shift ~50 minutes later each day, like the tide.</p>
          <h3 style="margin-top:2.4rem" class="wl">Almanac — next 7 days</h3>
          <div class="table-scroll">
            <table class="almanac" id="almanac">
              <thead><tr><th>Day</th><th>High</th><th>Low</th><th>High</th><th>Crossing windows</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </div>
      <p style="margin-top:2.6rem"><a class="btn amber" href="/apply">Reserve your seat</a></p>
    </div>
  </section>
</Layout>

<script>
  // Live tide clock + 7-day almanac (semidiurnal M2 model ≈ 12h 25m)
  const RM = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const PERIOD = 12.4206012 * 3600 * 1000, ANCHOR = Date.UTC(2026, 0, 1, 3, 37), THRESH = 0.42;
  const $ = (id: string) => document.getElementById(id)!;
  function tide(now: number) {
    const ph = (((now - ANCHOR) % PERIOD) + PERIOD) % PERIOD / PERIOD;
    const level = (Math.cos(ph * 2 * Math.PI) + 1) / 2, rising = ph > 0.5;
    const msToTurn = (ph < 0.5 ? 0.5 - ph : 1 - ph) * PERIOD;
    return { ph, level, rising, msToTurn, nextIsLow: ph < 0.5 };
  }
  const fmtDur = (ms: number) => { const m = Math.round(ms / 60000); return `${Math.floor(m / 60)}h ${String(m % 60).padStart(2, '0')}m`; };
  const fmtTime = (d: Date) => d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });

  if (document.getElementById('tideclock')) {
    const ticks = $('tc-ticks');
    for (let i = 0; i < 24; i++) { const a = i / 24 * 2 * Math.PI, r1 = 142, r2 = i % 6 ? 148 : 150; ticks.innerHTML += `<line x1="${160 + r1 * Math.sin(a)}" y1="${160 - r1 * Math.cos(a)}" x2="${160 + r2 * Math.sin(a)}" y2="${160 - r2 * Math.cos(a)}" stroke-width="${i % 6 ? 1 : 2}"/>`; }
    let waveOff = 0;
    function draw() {
      const t = tide(Date.now()), yWater = 288 - t.level * 208;
      $('tc-water').setAttribute('y', String(yWater)); $('tc-water').setAttribute('height', String(320 - yWater));
      let d = `M20 ${yWater}`; for (let x = 20; x <= 300; x += 10) d += ` Q ${x + 5} ${yWater + Math.sin((x + waveOff) / 22) * 3.5} ${x + 10} ${yWater}`;
      $('tc-wave').setAttribute('d', d); if (!RM) waveOff += 3;
      $('tc-needle').setAttribute('transform', `rotate(${t.ph * 360} 160 160)`);
      $('tc-pct').textContent = Math.round(t.level * 100) + '%';
      $('tc-dir').textContent = t.rising ? 'Rising ↑' : 'Falling ↓';
      const turn = new Date(Date.now() + t.msToTurn);
      $('tc-next').textContent = `${t.nextIsLow ? 'Low' : 'High'} ${fmtTime(turn)} · in ${fmtDur(t.msToTurn)}`;
      const closed = t.level > THRESH, pill = $('tc-status');
      pill.classList.toggle('open', !closed);
      $('tc-status-text').textContent = closed ? 'Stranded — causeway under water' : 'Causeway open — crossing window';
    }
    draw(); setInterval(draw, RM ? 30000 : 120);

    const alBody = document.querySelector('#almanac tbody')!;
    const dayFmt = (d: Date) => d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
    const rows: string[] = [];
    for (let dd = 0; dd < 7; dd++) {
      const ds = new Date(); ds.setHours(0, 0, 0, 0); ds.setDate(ds.getDate() + dd);
      const t0 = ds.getTime(), t1 = t0 + 86400000, highs: Date[] = [], lows: Date[] = [];
      let k = Math.floor((t0 - ANCHOR) / PERIOD) - 1;
      for (; ; k++) { const hi = ANCHOR + k * PERIOD, lo = hi + PERIOD / 2; if (hi >= t1 && lo >= t1) break; if (hi >= t0 && hi < t1) highs.push(new Date(hi)); if (lo >= t0 && lo < t1) lows.push(new Date(lo)); }
      const win = lows.map((l) => `${fmtTime(new Date(l.getTime() - 105 * 6e4))}–${fmtTime(new Date(l.getTime() + 105 * 6e4))}`).join(' · ');
      rows.push(`<tr><td>${dayFmt(ds)}</td><td class="hi">${highs[0] ? fmtTime(highs[0]) : '—'}</td><td>${lows.map(fmtTime).join(' / ') || '—'}</td><td class="hi">${highs[1] ? fmtTime(highs[1]) : '—'}</td><td>${win || '—'}</td></tr>`);
    }
    alBody.innerHTML = rows.join('');
  }
</script>
